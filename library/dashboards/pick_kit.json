  "widgets": [
    {
      "id": "explainer",
      "type": "HtmlBox",
      "config": {
        "htmlContent": {
          "de": "<div style=\"max-width: 660px; padding: 6px 8px 12px;\"><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;\">Pick-Kit · Kommissionierung</div><h1 style=\"font-size: 28px; font-weight: 600; line-height: 1.12; letter-spacing: -0.02em; color: var(--text); margin: 0 0 12px;\">Bau dir deine Pick-App — für genau deinen Prozess.</h1><p style=\"font-size: 14px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 20px; max-width: 520px;\">Kommissionierung ist überall anders. Mit dem Pick-Kit baust du dir per Sprache angepasste Pick-Apps — genau so, wie dein Lager arbeitet. Kein Standard von der Stange, sondern deine.</p><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin: 6px 0 10px;\">Deine MCP-Adresse</div><div style=\"background: var(--surface-hover); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; margin: 4px 0 22px; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;\"><code style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; color: var(--text); word-break: break-all; line-height: 1.45;\">{{mcp_url}}</code><button data-copy=\"{{mcp_url}}\" aria-label=\"Kopieren\" style=\"background: transparent; color: var(--brand); border: 1px solid var(--brand-border); border-radius: 6px; padding: 5px 7px; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; justify-content: center; line-height: 0;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"/><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/></svg></button></div><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin: 6px 0 10px;\">So baust du deine erste Pick-App</div><ol style=\"margin: 0 0 22px; padding-left: 20px;\"><li style=\"font-size: 13.5px; line-height: 1.6; color: var(--text-secondary); margin-bottom: 7px;\">Trag die Adresse oben in Claude, Codex &amp; Co. als Connector ein.</li><li style=\"font-size: 13.5px; line-height: 1.6; color: var(--text-secondary); margin-bottom: 7px;\">Sag: „Bau mir eine Pick-App für Batch-Picking mit Barcode-Scan\".</li><li style=\"font-size: 13.5px; line-height: 1.6; color: var(--text-secondary); margin-bottom: 7px;\">Deine App erscheint im Studio — anpassen, öffnen, loslegen.</li></ol><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin: 6px 0 10px;\">Pick-Strategien, die du abbilden kannst</div><div style=\"margin-bottom: 4px;\"><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Einzelkommissionierung</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Batch-Picking</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Zonen-Picking</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Wave-Picking</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Pick-by-Scan</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Pick-by-Light</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Mobile Kommissionierung</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Cluster-Picking</span></div></div>",
          "en": "<div style=\"max-width: 660px; padding: 6px 8px 12px;\"><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;\">Pick Kit · Picking</div><h1 style=\"font-size: 28px; font-weight: 600; line-height: 1.12; letter-spacing: -0.02em; color: var(--text); margin: 0 0 12px;\">Build your own pick app — for exactly your process.</h1><p style=\"font-size: 14px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 20px; max-width: 520px;\">Picking works differently everywhere. With the Pick Kit you build tailored pick apps by conversation — exactly how your warehouse works. Not an off-the-shelf default, but yours.</p><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin: 6px 0 10px;\">Your MCP address</div><div style=\"background: var(--surface-hover); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; margin: 4px 0 22px; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;\"><code style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; color: var(--text); word-break: break-all; line-height: 1.45;\">{{mcp_url}}</code><button data-copy=\"{{mcp_url}}\" aria-label=\"Copy\" style=\"background: transparent; color: var(--brand); border: 1px solid var(--brand-border); border-radius: 6px; padding: 5px 7px; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; justify-content: center; line-height: 0;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"/><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/></svg></button></div><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin: 6px 0 10px;\">Build your first pick app</div><ol style=\"margin: 0 0 22px; padding-left: 20px;\"><li style=\"font-size: 13.5px; line-height: 1.6; color: var(--text-secondary); margin-bottom: 7px;\">Add the address above as a connector in Claude, Codex &amp; co.</li><li style=\"font-size: 13.5px; line-height: 1.6; color: var(--text-secondary); margin-bottom: 7px;\">Say: \"Build me a pick app for batch picking with barcode scanning\".</li><li style=\"font-size: 13.5px; line-height: 1.6; color: var(--text-secondary); margin-bottom: 7px;\">Your app appears in Studio — adjust it, open it, go.</li></ol><div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin: 6px 0 10px;\">Picking strategies you can model</div><div style=\"margin-bottom: 4px;\"><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Single-order</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Batch picking</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Zone picking</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Wave picking</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Pick-by-scan</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Pick-by-light</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Mobile picking</span><span style=\"display: inline-block; font-size: 12px; color: var(--text-secondary); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; margin: 0 6px 7px 0;\">Cluster picking</span></div></div>"
        }
      }
