{
  "id": "onboarding_setup",
  "version": 4,
  "icon": "rocket",
  "category": "setup",
  "order": 1,
  "widgets": [
    {
      "id": "cockpit",
      "type": "HtmlBox",
      "config": {
        "htmlContent": {
          "de": "<div style=\"max-width: 560px; padding: 4px 8px 16px;\">\n\n  <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand); margin-bottom: 22px;\">\n    Xentral AI &nbsp;·&nbsp; Setup\n  </div>\n\n  <h1 style=\"font-size: 32px; font-weight: 600; line-height: 1.08; letter-spacing: -0.022em; color: var(--text); margin: 0 0 14px;\">\n    Drei Schritte,<br/>dann denkt deine ERP mit.\n  </h1>\n\n  <p style=\"font-size: 14px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 12px; max-width: 480px;\">\n    Verbinde Claude, Codex &amp; Co. mit deinem Tenant, lade den Onboarding-Coach und sag den Startsatz. Etwa fünf Minuten.\n  </p>\n\n  <div style=\"display: inline-flex; align-items: center; gap: 10px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; color: var(--text-muted); margin-bottom: 36px;\">\n    <span style=\"display: inline-block; width: 28px; height: 1px; background: var(--brand);\"></span>\n    <span>01 &nbsp;·&nbsp; 02 &nbsp;·&nbsp; 03</span>\n    <span style=\"display: inline-block; width: 28px; height: 1px; background: var(--line);\"></span>\n    <span style=\"color: var(--text-muted);\">~5 Min</span>\n  </div>\n\n  <!-- Step 01 ────────────────────────────────────────── -->\n  <section style=\"display: grid; grid-template-columns: 48px 1fr; gap: 4px; padding-top: 28px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; font-weight: 600; color: var(--brand); padding-top: 4px; letter-spacing: 0.04em;\">01</div>\n    <div>\n      <h2 style=\"font-size: 17px; font-weight: 600; color: var(--text); margin: 0 0 6px; letter-spacing: -0.01em;\">Connector verbinden</h2>\n      <p style=\"font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; margin: 0 0 16px; max-width: 440px;\">\n        Eine Brücke zwischen Claude, Codex &amp; Co. und deinem Tenant. Eine URL — funktioniert für Browser, Desktop und CLI.\n      </p>\n\n      <div style=\"background: var(--surface-hover); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; margin-bottom: 16px; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;\">\n        <code style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; color: var(--text); word-break: break-all; line-height: 1.45;\">{{mcp_url}}</code>\n        <button data-copy=\"{{mcp_url}}\" aria-label=\"Kopieren\" style=\"background: transparent; color: var(--brand); border: 1px solid var(--brand-border); border-radius: 6px; padding: 5px 7px; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; justify-content: center; line-height: 0;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"/><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/></svg></button>\n      </div>\n    </div>\n  </section>\n\n  <!-- Step 02 ────────────────────────────────────────── -->\n  <section style=\"display: grid; grid-template-columns: 48px 1fr; gap: 4px; padding-top: 30px; margin-top: 30px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; font-weight: 600; color: var(--brand); padding-top: 4px; letter-spacing: 0.04em;\">02</div>\n    <div>\n      <h2 style=\"font-size: 17px; font-weight: 600; color: var(--text); margin: 0 0 6px; letter-spacing: -0.01em;\">Onboarding-Coach laden</h2>\n      <p style=\"font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; margin: 0 0 16px; max-width: 440px;\">\n        Macht aus deinem KI-Client einen Xentral-Coach, der dein Business kennt und deinen Tenant aufbaut.\n      </p>\n\n      <div style=\"display: flex; flex-wrap: wrap; align-items: center; gap: 14px; row-gap: 10px;\">\n        <span style=\"font-size: 13px;\">{{skill_download_link}}</span>\n        <span style=\"font-size: 12.5px; color: var(--text-muted);\">oder in Claude über <a href=\"https://claude.ai/skills\" target=\"_blank\" rel=\"noreferrer\" style=\"color: var(--text); text-decoration: none; border-bottom: 1px solid var(--brand-border); padding-bottom: 1px;\">claude.ai/skills</a> nach <span style=\"color: var(--text);\">„Xentral Onboarding-Coach\"</span> suchen</span>\n      </div>\n    </div>\n  </section>\n\n  <!-- Step 03 ────────────────────────────────────────── -->\n  <section style=\"display: grid; grid-template-columns: 48px 1fr; gap: 4px; padding-top: 30px; margin-top: 30px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; font-weight: 600; color: var(--brand); padding-top: 4px; letter-spacing: 0.04em;\">03</div>\n    <div>\n      <h2 style=\"font-size: 17px; font-weight: 600; color: var(--text); margin: 0 0 6px; letter-spacing: -0.01em;\">Coach starten</h2>\n      <p style=\"font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; margin: 0 0 16px; max-width: 440px;\">\n        Öffne deinen KI-Client und schick diesen einen Satz.\n      </p>\n\n      <div style=\"background: var(--surface-hover); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;\">\n        <code style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; color: var(--text); line-height: 1.45;\">Bitte starte mein Xentral-Onboarding.</code>\n        <button data-copy=\"Bitte starte mein Xentral-Onboarding.\" aria-label=\"Kopieren\" style=\"background: transparent; color: var(--brand); border: 1px solid var(--brand-border); border-radius: 6px; padding: 5px 7px; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; justify-content: center; line-height: 0;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"/><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/></svg></button>\n      </div>\n    </div>\n  </section>\n\n  <!-- After ──────────────────────────────────────────── -->\n  <section style=\"margin-top: 44px; padding-top: 24px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 18px;\">\n      Was dann passiert\n    </div>\n    <div style=\"display: grid; gap: 12px; font-size: 13.5px; line-height: 1.55; color: var(--text-secondary);\">\n      <div style=\"display: grid; grid-template-columns: 22px 1fr; gap: 4px; align-items: baseline;\"><span style=\"color: var(--brand); font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\">→</span><span>Der Coach stellt zwei bis drei Fragen zu deinem Business</span></div>\n      <div style=\"display: grid; grid-template-columns: 22px 1fr; gap: 4px; align-items: baseline;\"><span style=\"color: var(--brand); font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\">→</span><span>Er baut deinen maßgeschneiderten Setup-Plan</span></div>\n      <div style=\"display: grid; grid-template-columns: 22px 1fr; gap: 4px; align-items: baseline;\"><span style=\"color: var(--brand); font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\">→</span><span>Diese Seite zeigt dir live, wie er deinen Tenant aufbaut</span></div>\n    </div>\n  </section>\n\n</div>\n",
          "en": "<div style=\"max-width: 560px; padding: 4px 8px 16px;\">\n\n  <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand); margin-bottom: 22px;\">\n    Xentral AI &nbsp;·&nbsp; Setup\n  </div>\n\n  <h1 style=\"font-size: 32px; font-weight: 600; line-height: 1.08; letter-spacing: -0.022em; color: var(--text); margin: 0 0 14px;\">\n    Three steps,<br/>then your ERP thinks with you.\n  </h1>\n\n  <p style=\"font-size: 14px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 12px; max-width: 480px;\">\n    Connect Claude, Codex &amp; Co. to your tenant, load the onboarding coach, send the kick-off line. About five minutes.\n  </p>\n\n  <div style=\"display: inline-flex; align-items: center; gap: 10px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; color: var(--text-muted); margin-bottom: 36px;\">\n    <span style=\"display: inline-block; width: 28px; height: 1px; background: var(--brand);\"></span>\n    <span>01 &nbsp;·&nbsp; 02 &nbsp;·&nbsp; 03</span>\n    <span style=\"display: inline-block; width: 28px; height: 1px; background: var(--line);\"></span>\n    <span style=\"color: var(--text-muted);\">~5 min</span>\n  </div>\n\n  <!-- Step 01 ────────────────────────────────────────── -->\n  <section style=\"display: grid; grid-template-columns: 48px 1fr; gap: 4px; padding-top: 28px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; font-weight: 600; color: var(--brand); padding-top: 4px; letter-spacing: 0.04em;\">01</div>\n    <div>\n      <h2 style=\"font-size: 17px; font-weight: 600; color: var(--text); margin: 0 0 6px; letter-spacing: -0.01em;\">Connect the bridge</h2>\n      <p style=\"font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; margin: 0 0 16px; max-width: 440px;\">\n        One URL bridges Claude, Codex &amp; Co. and your tenant. Works for browser, desktop and CLI.\n      </p>\n\n      <div style=\"background: var(--surface-hover); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; margin-bottom: 16px; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;\">\n        <code style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; color: var(--text); word-break: break-all; line-height: 1.45;\">{{mcp_url}}</code>\n        <button data-copy=\"{{mcp_url}}\" aria-label=\"Copy\" style=\"background: transparent; color: var(--brand); border: 1px solid var(--brand-border); border-radius: 6px; padding: 5px 7px; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; justify-content: center; line-height: 0;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"/><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/></svg></button>\n      </div>\n    </div>\n  </section>\n\n  <!-- Step 02 ────────────────────────────────────────── -->\n  <section style=\"display: grid; grid-template-columns: 48px 1fr; gap: 4px; padding-top: 30px; margin-top: 30px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; font-weight: 600; color: var(--brand); padding-top: 4px; letter-spacing: 0.04em;\">02</div>\n    <div>\n      <h2 style=\"font-size: 17px; font-weight: 600; color: var(--text); margin: 0 0 6px; letter-spacing: -0.01em;\">Load the onboarding coach</h2>\n      <p style=\"font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; margin: 0 0 16px; max-width: 440px;\">\n        Turns your AI client into a Xentral-trained coach that knows your business and builds your tenant with you.\n      </p>\n\n      <div style=\"display: flex; flex-wrap: wrap; align-items: center; gap: 14px; row-gap: 10px;\">\n        <span style=\"font-size: 13px;\">{{skill_download_link}}</span>\n        <span style=\"font-size: 12.5px; color: var(--text-muted);\">or in Claude under <a href=\"https://claude.ai/skills\" target=\"_blank\" rel=\"noreferrer\" style=\"color: var(--text); text-decoration: none; border-bottom: 1px solid var(--brand-border); padding-bottom: 1px;\">claude.ai/skills</a>, search for <span style=\"color: var(--text);\">\"Xentral Onboarding Coach\"</span></span>\n      </div>\n    </div>\n  </section>\n\n  <!-- Step 03 ────────────────────────────────────────── -->\n  <section style=\"display: grid; grid-template-columns: 48px 1fr; gap: 4px; padding-top: 30px; margin-top: 30px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; font-weight: 600; color: var(--brand); padding-top: 4px; letter-spacing: 0.04em;\">03</div>\n    <div>\n      <h2 style=\"font-size: 17px; font-weight: 600; color: var(--text); margin: 0 0 6px; letter-spacing: -0.01em;\">Wake up the coach</h2>\n      <p style=\"font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; margin: 0 0 16px; max-width: 440px;\">\n        Open your AI client and send this single line.\n      </p>\n\n      <div style=\"background: var(--surface-hover); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;\">\n        <code style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; color: var(--text); line-height: 1.45;\">Please start my Xentral onboarding.</code>\n        <button data-copy=\"Please start my Xentral onboarding.\" aria-label=\"Copy\" style=\"background: transparent; color: var(--brand); border: 1px solid var(--brand-border); border-radius: 6px; padding: 5px 7px; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; justify-content: center; line-height: 0;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"/><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/></svg></button>\n      </div>\n    </div>\n  </section>\n\n  <!-- After ──────────────────────────────────────────── -->\n  <section style=\"margin-top: 44px; padding-top: 24px; border-top: 1px solid var(--line);\">\n    <div style=\"font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 18px;\">\n      What happens next\n    </div>\n    <div style=\"display: grid; gap: 12px; font-size: 13.5px; line-height: 1.55; color: var(--text-secondary);\">\n      <div style=\"display: grid; grid-template-columns: 22px 1fr; gap: 4px; align-items: baseline;\"><span style=\"color: var(--brand); font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\">→</span><span>The coach asks two or three questions about your business</span></div>\n      <div style=\"display: grid; grid-template-columns: 22px 1fr; gap: 4px; align-items: baseline;\"><span style=\"color: var(--brand); font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\">→</span><span>It builds your tailored setup plan</span></div>\n      <div style=\"display: grid; grid-template-columns: 22px 1fr; gap: 4px; align-items: baseline;\"><span style=\"color: var(--brand); font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\">→</span><span>This page shows the build live as the coach assembles your tenant</span></div>\n    </div>\n  </section>\n\n</div>\n"
        }
      }
    },
