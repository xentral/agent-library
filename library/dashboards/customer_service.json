      "type": "KpiGrid",
      "config": {
        "title_text": {
          "de": "Operativ",
          "en": "Operational"
        },
        "kpis": [
          "inbox_total",
          "intervention_required",
          "received_today",
          "high_risk_count",
          "done_today",
          "spam_today"
        ]
      }
    },
    {
      "id": "kpi_grid",
      "type": "KpiGrid",
      "config": {
        "title_key": "dashboards.mockup.kpi.title",
        "kpis": [
          "automation_rate",
          "avg_response_time",
          "csat",
          "first_contact_resolution",
          "escalations_today",
          "done_today"
        ]
      }
    },
    {
      "id": "tabs",
      "type": "TableTabs",
      "config": {
        "tabs": [
          {
            "id": "inbox",
            "label_key": "workspace.inbox",
            "view": "inbox",
            "scope": "customer_service",
            "count_kpi": "open_inquiries"
          },
          {
            "id": "orders",
            "label_key": "workspace.csTabSales",
            "view": "sales_orders",
            "default_status_filter": "released"
          },
          {
            "id": "returns",
            "label_key": "workspace.csTabReturns",
            "view": "return_orders",
            "default_status_filter": "released",
            "count_kpi": "returns_today"
          }
        ]
      }
    }
