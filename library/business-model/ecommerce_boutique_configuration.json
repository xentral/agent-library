        "zahlungen:provider": {
          "title": "Payment providers",
          "group": "Payments",
          "description": "Pro Provider Account-Daten + Webhook-URL + Refund-Berechtigung.\nProvider-Anbindung erfolgt mit den jeweiligen API-Keys aus\nder Schnittstellen-Sektion.\n",
          "sections": [
            {
              "id": "providers",
              "title": "Zahlungsanbieter",
              "hint": "Welche Provider aktiv sind und ob Auto-Refund per API erlaubt ist.",
              "human": [
                {
                  "text": "Provider-Accounts anlegen (Stripe / PayPal / Klarna)",
                  "why": "KYC + Vertragsabschluss können nur Geschäftsführer",
                  "inline": true
                },
                {
                  "text": "API-Keys + Webhook-Secrets eintragen",
                  "why": "Sensible Credentials, liegen nur im Provider-Dashboard",
                  "inline": true
                }
              ],
              "fields": [
                {
                  "id": "providers",
                  "type": "matrix",
                  "rows_ref": "payment_providers",
                  "columns": [
                    {
                      "id": "active",
                      "type": "checkbox",
                      "label": "Aktiv"
                    },
                    {
                      "id": "refund",
                      "type": "select",
                      "label": "Refund",
                      "options": [
                        {
                          "id": "auto",
                          "label": "Auto (per API)"
                        },
                        {
                          "id": "manual",
                          "label": "Manuell"
                        },
                        {
                          "id": "none",
                          "label": "Nicht möglich"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "auto-recon",
              "title": "Auto-Reconciliation",
              "hint": "Auto-Match gleicht Provider-Auszahlungen mit Bankkonto und offenen Forderungen ab.",
              "fields": [
                {
                  "id": "auto_match",
                  "type": "toggle",
                  "label": "Auto-Match mit Bankkonto aktiv",
                  "default": true
                },
                {
                  "id": "match_toleranz",
                  "type": "number",
                  "label": "Match-Toleranz (€)",
                  "hint": "Differenz unterhalb wird auto-akzeptiert.",
                  "default": "0.02",
                  "min": 0,
                  "step": 0.01,
                  "max_width": 120
                }
              ]
            }
          ]
        },
