      "modules": {
        "unternehmen:firma": {
          "title": "Company profile",
          "group": "Company",
          "description": "Legal name, registration number, tax IDs, address, contact\ndetails and brand assets — appear on every invoice/document\nand email footer.\n",
          "human_inputs": 8,
          "sections": [
            {
              "id": "company-form",
              "title": "Company & legal form",
              "hint": "Wer steht auf dem Beleg? Pflichtangaben aus Handelsregister + Steueranmeldung.",
              "human": [
                {
                  "text": "Confirm official company name",
                  "why": "Must match the commercial register exactly — legally binding on every document"
                },
                {
                  "text": "Confirm correct legal form",
                  "why": "Determines mandatory document fields and liability — wrong form = wrong invoices"
                }
              ],
              "fields": [
                {
                  "id": "company_name",
                  "type": "text",
                  "label": "Firmenname (offiziell)",
                  "default": "Beispiel D2C GmbH",
                  "human": true,
                  "human_why": "Muss exakt dem HR-Eintrag entsprechen — auf jedem Beleg rechtsverbindlich."
                },
                {
                  "id": "legal_form",
                  "type": "radio",
                  "label": "Rechtsform",
                  "default": "gmbh",
                  "options_ref": "legal_forms",
                  "human": true,
                  "human_why": "Bestimmt Pflichtangaben & Haftung. Falsche Form führt zu falschen Belegen."
                },
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "hr_number",
                      "type": "text",
                      "label": "Handelsregister-Nr.",
                      "placeholder": "HRB 12345",
                      "default": "HRB 12345"
                    },
                    {
                      "id": "hr_court",
                      "type": "text",
                      "label": "Registergericht",
                      "placeholder": "Amtsgericht …",
                      "default": "Amtsgericht München"
                    }
                  ]
                }
              ]
            },
            {
              "id": "tax-identification",
              "title": "Steuer-Identifikation",
              "hint": "USt-ID erscheint auf jeder Rechnung. VIES-Validierung schützt vor Tippfehlern.",
              "human": [
                {
                  "text": "Provide VAT ID and tax number",
                  "why": "Issued by the tax office, not publicly retrievable"
                },
                {
                  "text": "Decide on small-business regulation (§19 UStG)",
                  "why": "Legal choice tied to expected annual revenue"
                }
              ],
              "fields": [
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "ust_id",
                      "type": "text",
                      "label": "USt-ID",
                      "default": "DE123456789",
                      "placeholder": "DE123456789"
                    },
                    {
                      "id": "tax_number",
                      "type": "text",
                      "label": "Steuernummer",
                      "default": "143/123/45678",
                      "placeholder": "143/123/45678",
                      "human": true,
                      "human_why": "Wird vom Finanzamt vergeben, nirgendwo öffentlich abrufbar."
                    }
                  ]
                },
                {
                  "layout": "toggle-group",
                  "fields": [
                    {
                      "id": "ustid_validate",
                      "type": "toggle",
                      "label": "USt-ID per VIES validieren (empfohlen)",
                      "default": true
                    },
                    {
                      "id": "kleinunternehmer",
                      "type": "toggle",
                      "label": "Kleinunternehmer-Regelung (§ 19 UStG) — keine USt auf Belegen",
                      "default": false
                    }
                  ]
                }
              ]
            },
            {
              "id": "address",
              "title": "Anschrift",
              "hint": "Geschäftsadresse für Belege und Korrespondenz. Abweichende Versandadresse pro Lager separat.",
              "fields": [
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "street",
                      "type": "text",
                      "label": "Straße",
                      "default": "Musterstr."
                    },
                    {
                      "id": "house_no",
                      "type": "text",
                      "label": "Hausnummer",
                      "default": "1",
                      "max_width": 120
                    }
                  ]
                },
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "zip",
                      "type": "text",
                      "label": "PLZ",
                      "default": "80331",
                      "max_width": 140
                    },
                    {
                      "id": "city",
                      "type": "text",
                      "label": "Ort",
                      "default": "München"
                    },
                    {
                      "id": "country",
                      "type": "text",
                      "label": "Land",
                      "default": "DE",
                      "placeholder": "DE",
                      "max_width": 100
                    }
                  ]
                }
              ]
            },
            {
              "id": "contact",
              "title": "Kontakt",
              "hint": "Adressen, die in Belegen, Bestellbestätigungen und im Impressum auftauchen.",
              "human": [
                {
                  "text": "Set up mailboxes and assign recipients",
                  "why": "Internal org decision — who reads what"
                },
                {
                  "text": "Provide phone hotline number (or none)",
                  "why": "Service policy decision"
                }
              ],
              "fields": [
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "main_email",
                      "type": "email",
                      "label": "Hauptmail / Belege",
                      "default": "hello@d2c.de",
                      "human": true,
                      "human_why": "Welche Inbox liest die Mails — interne Org-Entscheidung."
                    },
                    {
                      "id": "service_email",
                      "type": "email",
                      "label": "Service / Customer Care",
                      "default": "service@d2c.de",
                      "human": true,
                      "human_why": "Routing zur CS-Mailbox, kein Default ableitbar."
                    }
                  ]
                },
                {
                  "id": "hotline",
                  "type": "tel",
                  "label": "Hotline / Telefon",
                  "default": "+49 89 1234567",
                  "max_width": 220,
                  "human": true,
                  "human_why": "Service-Policy — eigene Nummer oder leer lassen."
                }
              ]
            },
            {
              "id": "branding",
              "title": "Branding",
              "hint": "Logo + Brandfarbe + Belegfußzeile — wird in jedem PDF (Rechnung, Lieferschein, Mahnung) verwendet.",
              "human": [
                {
                  "text": "Upload logo asset (transparent PNG, ≥ 600 px wide)",
                  "why": "Brand asset not retrievable from any public source"
                },
                {
                  "text": "Confirm brand color",
                  "why": "Brand identity decision, not machine-derivable"
                }
              ],
              "fields": [
                {
                  "id": "logo_url",
                  "type": "url",
                  "label": "Logo-URL",
                  "hint": "HTTPS-URL eines transparenten PNG, mind. 600 px breit.",
                  "default": "",
                  "placeholder": "https://cdn.d2c.de/logo.png",
                  "human": true,
                  "human_why": "Brand-Asset, liegt nirgendwo öffentlich abrufbar."
                },
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "brand_color",
                      "type": "text",
                      "label": "Brandfarbe (Hex)",
                      "default": "#6D7CFF",
                      "placeholder": "#6D7CFF",
                      "max_width": 160,
                      "human": true,
                      "human_why": "Marken-Identität, nicht maschinell entscheidbar."
                    }
                  ]
                },
                {
                  "id": "beleg_footer",
                  "type": "textarea",
                  "label": "Belegfußzeile",
                  "hint": "Pflichtangaben fürs Impressum auf Rechnungen — Firma, Anschrift, HR, USt-ID, Geschäftsführung.",
                  "default": "Beispiel D2C GmbH · Musterstr. 1 · 80331 München · HRB 12345 · USt-ID DE123456789 · Geschäftsführer: …",
                  "min_height": 80
                }
              ]
            }
          ]
        },
        "stammdaten:artikel": {
          "title": "Articles",
          "group": "Master data",
          "description": "Required fields + variants (size/color typical), images mandatory.",
