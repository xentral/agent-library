                    },
                    {
                      "id": "telefon",
                      "label": "Telefon"
                    },
                    {
                      "id": "lkz",
                      "label": "Lieferanten-Kennzahl"
                    }
                  ]
                }
              ]
            },
            {
              "id": "defaults",
              "title": "Defaults für neue Lieferanten",
              "hint": "Vorbelegungen — pro Lieferant überschreibbar.",
              "fields": [
                {
                  "id": "default_pay",
                  "type": "radio",
                  "label": "Standard-Zahlungsbedingung",
                  "default": "rechnung_30",
                  "options": [
                    {
                      "id": "vorkasse",
                      "label": "Vorkasse"
                    },
                    {
                      "id": "rechnung_14",
                      "label": "Rechnung 14 Tage"
                    },
                    {
                      "id": "rechnung_30",
                      "label": "Rechnung 30 Tage"
                    },
                    {
                      "id": "rechnung_60",
                      "label": "Rechnung 60 Tage"
                    }
                  ]
                },
                {
                  "id": "default_we",
                  "type": "radio",
                  "label": "Default-Wareneingangs-Workflow",
                  "default": "stichprobe",
                  "options": [
                    {
                      "id": "direkt",
                      "label": "Direkt einlagern (Vertrauens-Lieferanten)"
                    },
                    {
                      "id": "stichprobe",
                      "label": "Stichprobe 10 % vor Einlagerung"
                    },
                    {
                      "id": "voll",
                      "label": "100 % QS vor Einlagerung"
                    }
                  ]
                },
                {
                  "id": "bewertung",
                  "type": "toggle",
                  "label": "Lieferanten-Bewertung aktiv (Liefertreue · Qualität · Preis)",
                  "default": true
                }
              ]
            }
          ]
        },
        "stammdaten:nummernkreise": {
          "title": "Number ranges",
          "group": "Master data",
          "description": "Xentral defaults — yearly reset.",
          "human_inputs": 0
        },
        "vertrieb:auftraege": {
          "title": "Orders & workflow",
          "group": "Sales",
          "description": "Status-Workflow + Auto-Beleg-Trigger + Hold-Bedingungen +\nTeillieferung + Storno-Frist.\n",
          "sections": [
            {
              "id": "status-workflow",
              "title": "Status-Workflow",
              "hint": "Welche Belege automatisch erzeugt werden und wann.",
              "fields": [
                {
                  "id": "auto_ls",
                  "type": "toggle",
                  "label": "Lieferschein automatisch bei Versand erzeugen",
                  "default": true
                },
                {
                  "id": "auto_rg",
                  "type": "toggle",
                  "label": "Rechnung automatisch erzeugen",
                  "default": true
                },
                {
                  "id": "rg_trigger",
                  "type": "radio",
                  "label": "Rechnungs-Trigger",
                  "default": "shipment",
                  "show_if": {
                    "field": "auto_rg",
                    "equals": true
                  },
                  "options": [
                    {
                      "id": "shipment",
                      "label": "Bei Versand",
                      "hint": "Standard im D2C"
                    },
                    {
                      "id": "payment",
                      "label": "Bei Zahlungseingang",
                      "hint": "Bei Vorkasse-Geschäft"
                    },
                    {
                      "id": "manual",
                      "label": "Manuell auslösen",
                      "hint": "Selten — verlangsamt Cash-Flow"
                    }
                  ]
                }
              ]
            },
            {
              "id": "holds",
              "title": "Hold-Bedingungen",
              "hint": "Wann eine Bestellung manuell freigegeben werden muss.",
              "fields": [
                {
                  "id": "holds",
                  "type": "checkbox-multi",
