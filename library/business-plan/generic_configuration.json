                  "id": "pflicht",
                  "type": "checkbox-multi",
                  "label": "",
                  "default": [
                    "firma",
                    "iban",
                    "ustid",
                    "ansprech"
                  ],
                  "options": [
                    {
                      "id": "firma",
                      "label": "Firma"
                    },
                    {
                      "id": "iban",
                      "label": "IBAN"
                    },
                    {
                      "id": "ustid",
                      "label": "USt-ID"
                    },
                    {
                      "id": "ansprech",
                      "label": "Hauptansprechpartner"
                    },
                    {
                      "id": "email",
