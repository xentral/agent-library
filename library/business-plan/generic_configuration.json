                    },
                    {
                      "id": "stock",
                      "label": "Bestand 0 oder negativ"
                    },
                    {
                      "id": "first",
                      "label": "Erstbestellung ab Schwellenwert"
                    },
                    {
                      "id": "fraud",
                      "label": "Fraud-Score erhöht (vom Provider)"
                    }
                  ]
                }
              ]
            },
            {
              "id": "delivery-cancel",
              "title": "Lieferung & Stornos",
              "hint": "Teillieferung, Storno-Frist, Mindestbestellwert.",
              "human": [
                {
                  "text": "Mindestbestellwert entscheiden",
                  "why": "Hängt am durchschnittlichen Warenkorb + Versandkosten-Modell",
                  "inline": true
                }
              ],
              "fields": [
                {
                  "id": "teil_lieferung",
                  "type": "toggle",
                  "label": "Teillieferung erlaubt + Auto-Backorder",
                  "default": true
                },
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "storno_frist",
                      "type": "number",
                      "label": "Storno-Frist (Tage)",
                      "hint": "Gesetzlich 14 Tage Widerruf bei B2C.",
                      "default": "14",
                      "min": 0,
                      "max_width": 120
                    },
                    {
                      "id": "mindest_bw",
                      "type": "number",
                      "label": "Mindestbestellwert €",
                      "hint": "0 = kein Mindestwert.",
                      "default": "0",
                      "min": 0,
                      "max_width": 140
                    }
                  ]
                }
              ]
            }
          ]
        },
        "vertrieb:preise": {
          "title": "Prices & discounts",
          "group": "Sales",
          "description": "Single Standard price list, no tier pricing.",
          "human_inputs": 1
        },
        "finanzen:steuer": {
          "title": "Tax & OSS",
          "group": "Finance & tax",
          "description": "DE-Standardsätze + OSS-Aktivierung + EU-Länderliste +\nReverse-Charge + Drittland-Handling.\n",
          "sections": [
            {
              "id": "de-rates",
              "title": "DE-Steuersätze",
              "hint": "Pflicht-Defaults für deutsche Belege. Pro Artikel/Warengruppe kann der Satz überschrieben werden.",
              "fields": [
                {
                  "layout": "row",
                  "fields": [
                    {
                      "id": "standard_satz",
                      "type": "number",
                      "label": "Standard-Satz (%)",
                      "default": "19",
                      "min": 0,
                      "max": 30,
                      "max_width": 100
                    },
                    {
                      "id": "reduziert_satz",
                      "type": "number",
                      "label": "Reduzierter Satz (%)",
                      "default": "7",
                      "min": 0,
                      "max": 30,
                      "max_width": 100
                    }
                  ]
                },
                {
                  "id": "kleinunternehmer",
                  "type": "toggle",
                  "label": "Kleinunternehmer (§ 19 UStG) — keine USt auf Belegen, OSS nicht relevant",
                  "default": false
                }
              ]
            },
            {
              "id": "oss",
              "title": "OSS — One-Stop-Shop für EU-B2C",
