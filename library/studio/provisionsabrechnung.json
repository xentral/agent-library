  "files": [
    {
      "path": "app.yaml",
      "lang": "yaml",
      "content": "name: Provisionsabrechnung\nversion: 1\nplatform: web\nentities:\n  - CommissionRule\n  - CommissionStatement\nscreens:\n  - pv_rules\n  - pv_run\ntrigger:\n  schedule: \"0 2 1 * *\"   # Monatsanfang"
    },
    {
      "path": "rules/commission.py",
      "lang": "python",
      "content": "def commission_for(invoice, rule):\n    \"\"\"Provision einer Rechnung nach Regel-Bezug + Basis.\"\"\"\n    if not rule.matches(invoice):\n        return 0.0\n    base = invoice.margin if rule.basis == 'margin' else invoice.revenue\n    return round(base * rule.rate / 100, 2)\n"
    }
  ]
