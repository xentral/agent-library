      "path": "rules/booking.py",
      "lang": "python",
      "content": "def book(movement):\n    \"\"\"Validiert und verbucht eine Lagerbewegung.\"\"\"\n    if movement.type == 'transfer' and movement.from_bin == movement.to_bin:\n        raise ValueError('Quell- und Zielplatz sind identisch')\n    if movement.quantity <= 0:\n        raise ValueError('Menge muss positiv sein')\n    return ledger.append(movement)\n"
