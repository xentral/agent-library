  "files": [
    {
      "path": "app.yaml",
      "lang": "yaml",
      "content": "name: Bestellvorschlag\nversion: 1\nplatform: web\nentities:\n  - PurchaseProposal\nscreens:\n  - bv_home\n  - bv_history\ntrigger:\n  schedule: \"0 6 * * 1-5\"   # werktags 06:00 neu berechnen"
    },
    {
      "path": "rules/reorder.py",
      "lang": "python",
      "content": "def proposal_qty(stock, avg_daily_use, lead_days, growth_pct, seasonal):\n    \"\"\"Nachbestellmenge inkl. Wachstum + Saisonfaktor.\"\"\"\n    demand = avg_daily_use * lead_days\n    demand *= (1 + growth_pct / 100)\n    demand *= seasonal.factor_for_now()\n    return max(0, round(demand - stock))\n"
    }
  ]
