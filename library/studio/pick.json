      "path": "rules/route.py",
      "lang": "python",
      "content": "def optimize(tasks, layout):\n    \"\"\"Sortiert offene Pickpositionen nach kürzestem Laufweg.\"\"\"\n    return sorted(tasks, key=lambda t: layout.distance_to(t.bin))\n"
